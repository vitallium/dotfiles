#:schema https://mise.jdx.dev/schema/mise.json
[settings]
experimental = true
disable_backends = ["asdf", "vfox"]
legacy_version_file = true
not_found_auto_install = false
idiomatic_version_file_enable_tools = [
  "ruby",
  "rust",
  "python",
  "node",
  "go",
  "terraform",
  "yarn",
]

[settings.status]
show_env = true
show_tools = false

[settings.npm]
bun = true

[settings.pipx]
# Allow mise to install pipx packages without manual installation of pipx.
uvx = true

[settings.cargo]
binstall = true

[tools]
# Keep Rust on top to satisfy dependencies
rust = { version = "latest", components = "rust-analyzer,rust-src" }
biome = "latest"
bun = "latest"
cargo-binstall = "latest"
codex = "latest"
cosign = "3"
chezmoi = "2"
go = "latest"
gum = "latest"
hadolint = "latest"
hivemind = "latest"
java = "lts"
just = "latest"
kubectl = "latest"
lazygit = "latest"
node = "lts"
opencode = "latest"
pnpm = "latest"
prettier = "latest"
python = "3.13.13"
ruby = { version = "4.0.5", depends = ["rust"] }
shellcheck = "latest"
shfmt = "latest"
usage = "latest"
uv = "latest"
vale = "latest"
watchexec = "latest"

"aqua:AlexanderGrooff/mermaid-ascii" = "latest"
"aqua:golangci/golangci-lint" = "latest"
"aqua:sharkdp/hexyl" = "latest"

# Rust
"cargo:ast-grep" = { version = "latest", depends = ["cargo-binstall"] }
"cargo:bacon" = { version = "latest", depends = ["cargo-binstall"] }
"cargo:cargo-about" = { version = "latest", depends = ["cargo-binstall"] }
"cargo:cargo-audit" = { version = "latest", depends = ["cargo-binstall"] }
