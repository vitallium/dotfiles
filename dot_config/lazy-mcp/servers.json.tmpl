{
  "mode": "multi-server",
  "servers": [
{{- if .workconf }}
    {
      "name": "glean",
      "description": "GitLab enterprise search and knowledge discovery via Glean",
      "type": "remote",
      "url": "https://gitlab-be.glean.com/mcp/default"
    },
    {
      "name": "gitlab",
      "description": "GitLab MCP server",
      "type": "remote",
      "url": "https://gitlab.com/api/v4/mcp"
    },
    {
      "name": "gitlab-orbit",
      "description": "Query the GitLab Knowledge Graph (Orbit) via glab orbit remote CLI subcommands. Use for code-structure questions (who calls this function, where is this symbol defined), cross-project dependency and blast-radius analysis, merge-request and contributor queries, and any question answerable by traversing GitLab's unified entity graph (projects, users, MRs, issues, pipelines, files, definitions, vulnerabilities).",
      "type": "remote",
      "url": "https://gitlab.com/api/v4/orbit/mcp"
    },
{{- else }}
    {
      "name": "railway",
      "description": "Interact with Railway projects and infrastructure",
      "type": "local",
      "command": ["npx", "-y", "@railway/mcp-server"]
    },
    {
      "name": "cloudflare",
      "description": "Interact with Cloudflare",
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp"
    },
{{- end }}
    {
      "name": "chrome-devtools",
      "description": "Chrome DevTools automation and debugging",
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp"]
    },
    {
      "name": "context7",
      "description": "Library documentation and code examples",
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"]
    },
    {
      "name": "excalidraw",
      "description": "Excalidraw",
      "type": "remote",
      "url": "https://mcp.excalidraw.com"
    },
    {
      "name": "obsidian",
      "description": "Obsidian",
      "type": "local",
      "command": ["npx", "-y", "@bitbonsai/mcpvault", "{{ .obsidian.vault_path }}"]
    },
    {
      "name": "container-use",
      "description": "Sandboxed dev environments for coding agents",
      "type": "local",
      "command": ["container-use", "stdio"],
      "env": {
        "DOCKER_HOST": "unix://${HOME}/.config/colima/default/docker.sock"
      }
    }
  ],
  "discovery": {
    "cache_strategy": "session",
    "cache_ttl": 3600
  }
}
