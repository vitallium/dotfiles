{
  "cli_default_open_behavior": "new_window",
{{- if not .workconf }}
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "agent": {
    "default_profile": "write",
    "default_model": {
      "effort": "medium",
      "provider": "zed.dev",
      "model": "gpt-5.3-codex",
    },
  },
  "edit_predictions": {
    "mode": "subtle",
    "provider": "zed",
  },
{{- else }}
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-5"
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "collaboration_panel": {
    "button": false
  },
  "edit_predictions": {
    "provider": "none",
  },
{{- end }}
  "theme": {
    "light": "Modus Operandi",
    "dark": "Modus Vivendi Tinted"
  },
  "buffer_font_family": "{{ .zed.buffer_font.name }}",
  "buffer_font_size": {{ .zed.buffer_font.size }},
  "ui_font_family": "{{ .zed.ui_font.name }}",
  "terminal": {
    "font_family": "{{ .zed.terminal_font.name }}",
    "env": {
      "EDITOR": "zed --wait"
    }
  },
  "use_system_window_tabs": true,
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": false
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"]
  },
  "languages": {
    "Ruby": {
      "semantic_tokens": "combined",
      "language_servers": ["ruby-lsp"],
    },
  },
}
