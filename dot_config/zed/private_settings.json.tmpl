{
  "use_system_window_tabs": true,
{{- if .workconf }}
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "agent": {
    "default_profile": "write",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6"
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "collaboration_panel": {
    "button": false
  },
  "edit_predictions": {
    "provider": "none"
  },
{{- else }}
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "mistral-vibe": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "grok-build": {
      "type": "registry"
    }
  },
  "agent": {
    "default_profile": "container-use",
    "profiles": {
      "container-use": {
        "name": "Container Use",
        "tools": {
          "fetch": true,
          "thinking": true,
          "copy_path": false,
          "find_path": false,
          "delete_path": false,
          "create_directory": false,
          "list_directory": false,
          "diagnostics": false,
          "read_file": false,
          "open": false,
          "move_path": false,
          "grep": false,
          "edit_file": false,
          "terminal": false
        },
        "enable_all_context_servers": false,
        "context_servers": {
          "container-use": {
            "tools": {
              "environment_add_service": true,
              "environment_checkpoint": true,
              "environment_config": true,
              "environment_create": true,
              "environment_file_delete": true,
              "environment_file_edit": true,
              "environment_file_list": true,
              "environment_file_read": true,
              "environment_file_write": true,
              "environment_open": true,
              "environment_run_cmd": true,
              "environment_update_metadata": true
            }
          }
        }
      }
    },
    "default_model": {
      "effort": "medium",
      "provider": "zed.dev",
      "model": "gpt-5.5-codex"
    }
  },
  "edit_predictions": {
    "mode": "subtle",
    "provider": "zed"
  },
{{- end }}
  "theme": {
    "light": "Modus Operandi",
    "dark": "Modus Vivendi"
  },
  "buffer_font_family": "{{ .zed.buffer_font.name }}",
  "buffer_font_size": {{ .zed.buffer_font.size }},
  "markdown_preview_font_family": "{{ .zed.markdown_font.name }}",
  "ui_font_family": "{{ .zed.ui_font.name }}",
  "ui_font_size": {{ .zed.ui_font.size }},
  "terminal": {
    "font_family": "{{ .zed.terminal_font.name }}",
    "env": {
      "GIT_EDITOR": "zed --wait"
    }
  },
  "context_servers": {
    "lazy-mcp": {
      "command": "lazy-mcp",
      "args": ["--config", "~/.config/lazy-mcp/servers.json"]
    }
  },
  "languages": {
    "Ruby": {
      "semantic_tokens": "combined",
      "language_servers": ["ruby-lsp"]
    }
  }
}
