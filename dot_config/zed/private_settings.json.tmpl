{
  "cli_default_open_behavior": "new_window",
  "code_lens": "menu",
  "toolbar": {
    "code_actions": true
  },
{{- if .workconf }}
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "agent": {
    "dock": "right",
    "default_profile": "write",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6"
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "collaboration_panel": {
    "button": false
  },
  "edit_predictions": {
    "provider": "none"
  },
{{- else }}
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "mistral-vibe": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "grok-build": {
      "type": "registry"
    }
  },
  "agent": {
    "dock": "right",
    "default_profile": "write",
    "container-use": {
      "name": "Container Use",
      "tools": {
        "fetch": true,
        "thinking": true,
        "copy_path": false,
        "find_path": false,
        "delete_path": false,
        "create_directory": false,
        "list_directory": false,
        "diagnostics": false,
        "read_file": false,
        "open": false,
        "move_path": false,
        "grep": false,
        "edit_file": false,
        "terminal": false
      },
      "enable_all_context_servers": false,
      "context_servers": {
        "container-use": {
          "tools": {
            "environment_add_service": true,
            "environment_checkpoint": true,
            "environment_config": true,
            "environment_create": true,
            "environment_file_delete": true,
            "environment_file_edit": true,
            "environment_file_list": true,
            "environment_file_read": true,
            "environment_file_write": true,
            "environment_open": true,
            "environment_run_cmd": true,
            "environment_update_metadata": true
          }
        }
      }
    },
    "default_model": {
      "effort": "medium",
      "provider": "zed.dev",
      "model": "gpt-5.5-codex"
    }
  },
  "edit_predictions": {
    "mode": "subtle",
    "provider": "zed"
  },
  "collaboration_panel": {
    "dock": "left"
  },
{{- end }}
  "theme": {
    "light": "Modus Operandi",
    "dark": "Modus Vivendi"
  },
  "buffer_font_family": "{{ .zed.buffer_font.name }}",
  "buffer_font_size": {{ .zed.buffer_font.size }},
  "ui_font_family": "{{ .zed.ui_font.name }}",
  "markdown_preview_font_family": "{{ .zed.markdown_font.name }}",
  "terminal": {
    "font_family": "{{ .zed.terminal_font.name }}",
    "env": {
      "GIT_EDITOR": "zed --wait"
    }
  },
  "use_system_window_tabs": true,
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": false
  },
  "git_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "context_servers": {
    "lazy-mcp": {
      "command": "lazy-mcp",
      "args": ["--config", "~/.config/lazy-mcp/servers.json"]
    },
    "container-use": {
      "enabled": true,
      "remote": false,
      "command": "container-use",
      "args": ["stdio"],
      "env": {},
      "timeout": 300
    }
  },
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"],
    "Git Attributes": ["**/{git,.git,.git/info}/attributes"],
    "Git Config": ["*.gitconfig", "**/{git,.git/modules,.git/modules/*}/config"],
    "Git Commit": ["**/git-revise-todo", "**/{git,.git}/COMMIT_EDITMSG"],
    "Git Ignore": ["**/{git,.git}/ignore", "**/.git/info/exclude"],
    "JSONC": ["devcontainer.json"]
  },
  "languages": {
    "Git Commit": {
      "wrap_guides": [50, 72],
      "preferred_line_length": 72
    },
    "Ruby": {
      "semantic_tokens": "combined",
      "language_servers": ["ruby-lsp"]
    }
  },
  "profiles": {
    "Classic": {
      "settings": {
        "project_panel": {
          "dock": "left",
        },
        "agent": {
          "dock": "right",
          "sidebar_side": "right"
        },
      }
    },
    "Agentic": {
      "settings": {
        "project_panel": {
          "dock": "right",
        },
        "agent": {
          "dock": "left",
          "sidebar_side": "left"
        },
      }
    }
  }
}
