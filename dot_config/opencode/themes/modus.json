    "diffHighlightRemoved": { "dark": "vivRemovedFg", "light": "modusRemovedFg" },
    "diffAddedBg": { "dark": "vivAddedBg", "light": "modusAddedBg" },
    "diffRemovedBg": { "dark": "vivRemovedBg", "light": "modusRemovedBg" },
    "diffContextBg": { "dark": "vivBg", "light": "modusBg" },
    "diffLineNumber": { "dark": "vivLineNum", "light": "modusLineNum" },
    "diffAddedLineNumberBg": { "dark": "vivAddedBg", "light": "modusAddedBg" },
    "diffRemovedLineNumberBg": { "dark": "vivRemovedBg", "light": "modusRemovedBg" },

    "markdownText": { "dark": "vivFg", "light": "modusFg" },
    "markdownHeading": { "dark": "vivBlue", "light": "modusBlue" },
    "markdownLink": { "dark": "vivCyan", "light": "modusCyan" },
    "markdownLinkText": { "dark": "vivBlue", "light": "modusBlue" },
    "markdownCode": { "dark": "vivMagenta", "light": "modusMagenta" },
    "markdownBlockQuote": { "dark": "vivFgMuted", "light": "modusFgMuted" },
    "markdownEmph": { "dark": "vivViolet", "light": "modusViolet" },
    "markdownStrong": { "dark": "vivFg", "light": "modusFg" },
    "markdownHorizontalRule": { "dark": "vivBorder", "light": "modusBorder" },
    "markdownListItem": { "dark": "vivFg", "light": "modusFg" },
    "markdownListEnumeration": { "dark": "vivCyan", "light": "modusCyan" },
    "markdownImage": { "dark": "vivGreen", "light": "modusGreen" },
    "markdownImageText": { "dark": "vivFgMuted", "light": "modusFgMuted" },
    "markdownCodeBlock": { "dark": "vivMagenta", "light": "modusMagenta" },

    "syntaxComment": { "dark": "vivFgMuted", "light": "modusFgMuted" },
    "syntaxKeyword": { "dark": "vivViolet", "light": "modusViolet" },
    "syntaxFunction": { "dark": "vivMagenta", "light": "modusMagenta" },
    "syntaxVariable": { "dark": "vivFg", "light": "modusFg" },
    "syntaxString": { "dark": "vivBlue", "light": "modusBlue" },
    "syntaxNumber": { "dark": "vivGreen", "light": "modusGreen" },
    "syntaxType": { "dark": "vivCyan", "light": "modusCyan" },
    "syntaxOperator": { "dark": "vivFg", "light": "modusFg" },
    "syntaxPunctuation": { "dark": "vivFgMuted", "light": "modusFgMuted" },

    "inputBackground": { "dark": "vivBgAlt", "light": "modusBgAlt" },
    "InputBorder": { "dark": "vivBorder", "light": "modusBorder" },
    "InputBorderActive": { "dark": "vivBlue", "light": "modusBlue" },
    "inputPrompt": { "dark": "vivBlue", "light": "modusBlue" },
    "inputCursor": { "dark": "vivFg", "light": "modusFg" },
    "inputText": { "dark": "vivFg", "light": "modusFg" }
  }
}
