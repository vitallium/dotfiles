{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "modusBg": "#ffffff",
    "modusBgAlt": "#f0f0f0",
    "modusBgPanel": "#f2f2f2",
    "modusFg": "#000000",
    "modusFgMuted": "#595959",
    "modusBlue": "#3548cf",
    "modusViolet": "#531ab6",
    "modusMagenta": "#721045",
    "modusRed": "#a60000",
    "modusYellow": "#6f5500",
    "modusGreen": "#006800",
    "modusCyan": "#005077",
    "modusBorderSubtle": "#d0d0d0",
    "modusBorder": "#9f9f9f",
    "modusBorderActive": "#595959",
    "modusAddedBg": "#aef1b5",
    "modusRemovedBg": "#ffd0d0",
    "modusAddedFg": "#006800",
    "modusRemovedFg": "#a60000",
    "modusHunkHeader": "#005f5f",
    "modusLineNum": "#9f9f9f",

    "vivBg": "#000000",
    "vivBgAlt": "#1e1e1e",
    "vivBgPanel": "#2a2a2a",
    "vivFg": "#ffffff",
    "vivFgMuted": "#989898",
    "vivBlue": "#79a8ff",
    "vivViolet": "#b6a0ff",
    "vivMagenta": "#feacd0",
    "vivRed": "#ff5f59",
    "vivYellow": "#d0bc00",
    "vivGreen": "#44bc44",
    "vivCyan": "#00d3d0",
    "vivBorderSubtle": "#2a2a2a",
    "vivBorder": "#535353",
    "vivBorderActive": "#9f9f9f",
    "vivAddedBg": "#002600",
    "vivRemovedBg": "#3a0000",
    "vivAddedFg": "#44bc44",
    "vivRemovedFg": "#ff5f59",
    "vivHunkHeader": "#6ae4b9",
    "vivLineNum": "#535353"
  },
  "theme": {
    "primary": { "dark": "vivBlue", "light": "modusBlue" },
    "secondary": { "dark": "vivViolet", "light": "modusViolet" },
    "accent": { "dark": "vivCyan", "light": "modusCyan" },
    "error": { "dark": "vivRed", "light": "modusRed" },
    "warning": { "dark": "vivYellow", "light": "modusYellow" },
    "success": { "dark": "vivGreen", "light": "modusGreen" },
    "info": { "dark": "vivBlue", "light": "modusBlue" },
    "text": { "dark": "vivFg", "light": "modusFg" },
    "textMuted": { "dark": "vivFgMuted", "light": "modusFgMuted" },
    "background": { "dark": "vivBg", "light": "modusBg" },
    "backgroundPanel": { "dark": "vivBgAlt", "light": "modusBgAlt" },
    "backgroundElement": { "dark": "vivBgPanel", "light": "modusBgPanel" },
    "border": { "dark": "vivBorder", "light": "modusBorder" },
