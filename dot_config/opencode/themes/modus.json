    "borderSubtle": { "dark": "vivBorderSubtle", "light": "modusBorderSubtle" },

    "diffAdded": { "dark": "vivAddedFg", "light": "modusAddedFg" },
    "diffRemoved": { "dark": "vivRemovedFg", "light": "modusRemovedFg" },
    "diffContext": { "dark": "vivFgMuted", "light": "modusFgMuted" },
    "diffHunkHeader": { "dark": "vivHunkHeader", "light": "modusHunkHeader" },
